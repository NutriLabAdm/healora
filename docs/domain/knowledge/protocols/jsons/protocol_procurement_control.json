      "w": 0.68,
      "f": 0.75,
      "r": "weekly"
    },
    {
      "id": "PR_06",
      "name": "Zero Ultra-Processed Challenge",
      "name_ru": "Челлендж «0 ультра-обработанных»",
      "periodicity": "monthly",
      "w": 0.55,
      "f": 0.5,
      "r": "monthly"
    },
    {
      "id": "PR_07",
      "name": "Fridge Audit",
      "name_ru": "Аудит холодильника + списание просрочки",
      "periodicity": "weekly",
      "w": 0.6,
      "f": 1.0,
      "r": "weekly"
    }
  ],
  "red_flags": [
    {
      "metric": "Импульсивные покупки",
      "threshold": "> 2/неделя",
      "action": "Подключить PR_01 + PR_02"
    },
    {
      "metric": "Пустой холодильник на утро",
      "threshold": "≥ 3 раз/нед",
      "action": "Подключить PR_05 (batch prep)"
    },
    {
      "metric": "Расход на доставку > бюджета",
      "threshold": "> 3 раза/нед",
      "action": "План закупок на 2 недели"
    },
    {
      "metric": "«Я не знаю, что есть» в чате",
      "threshold": "> 2 раз/нед",
      "action": "Открыть список меню из PR_01"
    }
  ],
  "recommendations": [
    "Планировать меню на неделю каждый воскресный вечер (20–30 мин)",
    "Хранить список закупок в заметках телефона — добавлять в течение недели",
    "Не ходить в магазин голодным — риск импульсивных покупок выше в 2.7×",
    "Batch prep в субботу — экономит 5–7 ч в неделю",
    "При доставке продуктов — проверять корзину по правилу 70/30 перед заказом"
